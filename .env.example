# Copy this file to .secrets/.env and fill in real values.
# DO NOT commit .secrets/ — it is gitignored.

# --- Required ---------------------------------------------------------------
# Helius RPC + DAS API. Get one at https://www.helius.dev
HELIUS_API_KEY=

# --- Solana network ---------------------------------------------------------
# devnet | mainnet | testnet | localnet
NETWORK=devnet

# Optional override; otherwise the SDK builds the URL from HELIUS_API_KEY
# HELIUS_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_KEY
# HELIUS_SECURE_RPC_URL=https://your-devnet-staked-endpoint.helius-rpc.com

# --- Optional: Swaps & oracles ----------------------------------------------
# Jupiter API key (higher rate limits). https://station.jup.ag
JUPITER_API_KEY=

# Birdeye API key (price oracle). https://birdeye.so
BIRDEYE_API_KEY=

# --- Optional: AI agents -----------------------------------------------------
# Google Gemini for in-terminal analysis. https://aistudio.google.com
GOOGLE_AI_API_KEY=

# RedPill for TEE-attested AI inference. https://redpill.ai
REDPILL_API_KEY=

# --- Optional: Identity ------------------------------------------------------
# Path to a Solana keypair JSON; falls back to a generated wallet if unset
# SOLANA_KEYPAIR_PATH=~/.config/solana/id.json
