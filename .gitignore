# Dependencies
node_modules/

# Vendored upstream — fetch separately, never commit
magicblock-engine-examples-main/

# Secrets & credentials — NEVER commit these
.secrets/
.env
.env.*
*.env
!.env.example
client_secret_*.json
x402-*.json
*-keypair.json
id.json

# npm publish token — store in CI secret (NODE_AUTH_TOKEN), not in git
.npmrc
.npmrc.local
.npm

# Build outputs — allow SDK dist/ (needed for npm publish) and darkswap
build/
*.tsbuildinfo

# Ignore dist everywhere except the published SDK
dist/
!packages/sdk/dist/

# Anchor program build artifacts (large .so and C cache — rebuild from source)
dark-protocol-program/target/
dark-protocol-program/.anchor/

# DarkSwap — now its own repo
darkswap/

# Compiled output emitted next to TypeScript source
packages/protocol/**/*.js
packages/protocol/**/*.js.map
packages/protocol/**/*.d.ts
packages/protocol/**/*.d.ts.map

# Test/coverage
coverage/
.nyc_output/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editor / OS / local tooling
.DS_Store
.idea/
.vscode/
*.swp
Thumbs.db

# Project-local Claude Code settings — may contain personal tokens or paths
.claude/

# Playwright MCP browser session snapshots — dev tooling, not project source
.playwright-mcp/
