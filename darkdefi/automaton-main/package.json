{
  "name": "@conway/automaton",
  "version": "0.1.0",
  "description": "DarkDefi automaton runtime for guarded autonomous agent loops, persistence, identity, and release-machine primitives",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./config.js": {
      "types": "./dist/config.d.ts",
      "default": "./dist/config.js"
    },
    "./state/database.js": {
      "types": "./dist/state/database.d.ts",
      "default": "./dist/state/database.js"
    }
  },
  "bin": {
    "automaton": "dist/index.js",
    "conway-automaton": "dist/index.js"
  },
  "files": [
    "dist",
    "!dist/__tests__",
    "README.md",
    "LICENSE",
    "constitution.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/x402agent/DarkDefi.git",
    "directory": "automaton-main"
  },
  "homepage": "https://github.com/x402agent/DarkDefi/tree/main/automaton-main#readme",
  "keywords": [
    "autonomous-agent",
    "agent-runtime",
    "darkdefi",
    "solana",
    "release-automation",
    "x402",
    "interoperability",
    "web3-security"
  ],
  "license": "MIT",
  "scripts": {
    "build": "tsc && pnpm -r build",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "clean": "rm -rf dist && pnpm -r clean"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "chalk": "^5.3.0",
    "cron-parser": "^5.5.0",
    "gray-matter": "^4.0.3",
    "ora": "^9.4.0",
    "siwe": "^3.0.0",
    "simple-git": "^3.24.0",
    "ulid": "^3.0.2",
    "viem": "^2.48.11",
    "yaml": "^2.4.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^25.6.2",
    "tsx": "^4.7.0",
    "typescript": "^6.0.3",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
