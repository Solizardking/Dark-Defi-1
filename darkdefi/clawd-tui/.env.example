# OpenRouter API key — optional. If unset, `clawd` launches an OAuth PKCE
# login on first run and caches the key at ~/.config/openclawd/openrouter-key.
# Get a key at https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=

AGENT_MODEL=anthropic/claude-opus-4.7
AGENT_MAX_STEPS=20
AGENT_MAX_COST=1.0

# Birdeye API key — powers /trending /search /wallet /portfolio /networth and
# automatic on-paste analysis when a Solana contract address is entered.
# Get one at https://bds.birdeye.so/
BIRDEYE_API_KEY=

# Helius API key — powers /asset /assets /nfts /holders /sigs /balance and
# augments on-paste analysis with DAS metadata (NFTs, compressed assets,
# token supply). Get one at https://www.helius.dev/
HELIUS_API_KEY=
# Optional: override the default Helius RPC base. Pre-built URL with the
# api-key already embedded works too (e.g. https://mainnet.helius-rpc.com/?api-key=...)
# HELIUS_RPC_URL=https://mainnet.helius-rpc.com

# OpenClawd AutoResearch API base — powers /research and /autoloop. Defaults
# to http://localhost:8000 when running llm-wiki-tang locally. Set this when
# pointing at a remote/staging deployment of the wiki API.
# RESEARCH_API_URL=http://localhost:8000

# DeepSeek direct commands — powers /deepseek /deepseek-fim /deepseek-balance
# and /deepseek-models.
DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-v4-pro

# Browser Use compatibility for OpenClawd setup flows.
BROWSER_PROFILE=
BROWSER_PROFILE_ID=
BROWSER_USE_WORKSPACE_ID=
