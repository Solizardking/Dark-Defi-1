# Copy to .env.local and fill in real values.
# DO NOT commit .env or .env.local — they are gitignored.

# ── Required ──────────────────────────────────────────────────────────────────

# Helius RPC endpoint. Get a key at https://www.helius.dev
NEXT_PUBLIC_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY
HELIUS_API_KEY=YOUR_HELIUS_API_KEY

# Convex backend deployment URL. Run `npx convex dev` to create one.
NEXT_PUBLIC_CONVEX_URL=https://YOUR_DEPLOYMENT.convex.cloud
CONVEX_DEPLOYMENT=prod:YOUR_DEPLOYMENT

# ── Optional: Swaps ───────────────────────────────────────────────────────────

# Jupiter Swap API key (higher rate limits). https://station.jup.ag/api-keys
NEXT_PUBLIC_JUP_SWAP_V1_API_KEY=
JUPITER_API_KEY=
JUP_SWAP_V1_API_KEY=
JUPITER_ENDPOINT=https://api.jup.ag
JUPITER_ULTRA_ENDPOINT=https://api.jup.ag/ultra

# Jupiter referral account (optional fee sharing)
JUPITER_REFERRAL=
NEXT_PUBLIC_REFERRAL_KEY=
NEXT_PUBLIC_REFERRAL_ACCOUNT=

# ── Optional: Oracle ──────────────────────────────────────────────────────────

# Birdeye price oracle. https://birdeye.so
BIRDEYE_API_KEY=

# ── Optional: Token ───────────────────────────────────────────────────────────

# Featured token (e.g. your project token)
TOKEN_ADDRESS=
TOKEN_SYMBOL=

# ── Optional: AI / TEE ───────────────────────────────────────────────────────

# RedPill TEE-attested AI. https://redpill.ai
REDPILL_API_KEY=
REDPILL_MODEL=phala/qwen3-27b

# ── Optional: Advanced ───────────────────────────────────────────────────────

# DFlow RFQ endpoint (optional second quote source)
# DFLOW_QUOTE_API_URL=
# DFLOW_API_KEY=
