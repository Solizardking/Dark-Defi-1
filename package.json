{
  "name": "dark-defi-terminal",
  "version": "1.0.0",
  "description": "Dark Protocol DeFi Terminal with Privacy-Preserving Features",
  "private": true,
  "workspaces": [
    "packages/*",
    "programs/client"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "build:solana-client": "npm run build -w @clawd/solanaos-protocol-client",
    "build:sas": "npm run build -w sas-lib",
    "build:protocol": "tsc -p packages/protocol",
    "build:sdk": "npm run build -w @openclawdsol/dark-protocol-sdk",
    "build:terminal": "npm run build -w dark-x402-terminal",
    "build:tee": "npm run build -w @openclawdsol/dark-tee-agents",
    "terminal": "npm run dev -w dark-x402-terminal",
    "tee": "node packages/tee-agents/dist/cli.js",
    "tee:demo": "npm run build:tee && node packages/tee-agents/dist/demo.js",
    "clawd:demo": "npm run build:tee && node packages/tee-agents/dist/clawd-demo.js",
    "install:dark": "bash scripts/install-dark.sh",
    "clean": "rm -rf packages/*/dist packages/*/node_modules node_modules",
    "publish:all": "npm run build && npm publish --workspaces --access public"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  }
}
