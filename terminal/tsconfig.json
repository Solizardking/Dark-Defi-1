{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "../",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "allowSyntheticDefaultImports": true,
    "types": ["node"],
    "baseUrl": "../",
    "paths": {}
  },
  "include": [
    "../Protocol/**/*.ts",
    "./**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "../node_modules",
    "enhanced-google-ai-agent.ts"
  ]
}
